<?xml version="1.0" encoding="UTF-8"?>
<service id="remoting-service"
    class="flex.messaging.services.RemotingService">
 
    <adapters>
        <adapter-definition id="java-object" class="flex.messaging.services.remoting.adapters.JavaAdapter" default="true"/>
    </adapters>
 
    <default-channels>
        <channel ref="my-amf"/>
    </default-channels>
	<destination id="macroEconomicEntity">
        <properties>
            <source>org.bear.entity.MacroEconomicEntity</source>
        </properties>
    </destination>
    <destination id="jdbcMacroEconomicDao">
        <properties>
            <source>org.bear.dao.JdbcMacroEconomicDao</source>
        </properties>
    </destination>
    <destination id="buildMacroEconomicData">
        <properties>
            <source>org.bear.main.BuildMacroEconomicData</source>
        </properties>
    </destination>
    <destination id="buildRevenueData">
        <properties>
            <source>org.bear.main.BuildRevenueData</source>
        </properties>
    </destination>
    <destination id="financeUtil">
        <properties>
            <source>org.bear.financeAnalysis.FinanceUtil</source>
        </properties>
    </destination>
    <destination id="buffettAnalysis">
        <properties>
            <source>org.bear.financeAnalysis.BuffettAnalysis</source>
        </properties>
    </destination>
    <destination id="peterLynchAnalysis">
        <properties>
            <source>org.bear.financeAnalysis.PeterLynchAnalysis</source>
        </properties>
    </destination>
    <destination id="getJournalMetaData">
        <properties>
            <source>org.bear.journal.GetJournalMetaData</source>
        </properties>
    </destination>
    <destination id="updateJournalData">
        <properties>
            <source>org.bear.journal.UpdateJournalData</source>
        </properties>
    </destination>
    <destination id="buildAmericanMacroData">
        <properties>
            <source>org.bear.main.BuildAmericanMacroData</source>
        </properties>
    </destination>
    <destination id="buildPmIndex">
        <properties>
            <source>org.bear.main.BuildPMIndex</source>
        </properties>
    </destination>
    <destination id="redRabbitAnalysis">
        <properties>
            <source>org.bear.financeAnalysis.RedRabbitRevenueAnalysis</source>
        </properties>
    </destination>
    <destination id="roeAnalysis">
        <properties>
            <source>org.bear.financeAnalysis.RoeAnalysis</source>
        </properties>
    </destination>
    <destination id="distributionAnalysis">
        <properties>
            <source>org.bear.util.distribution.DistributionAnalysis</source>
        </properties>
    </destination>
    <destination id="perfectAnalysis">
        <properties>
            <source>org.bear.financeAnalysis.PerfectAnalysis</source>
        </properties>
    </destination>
    <destination id="juristicAnalysis">
        <properties>
            <source>org.bear.financeAnalysis.JuristicAnalysis</source>
        </properties>
    </destination>
    <destination id="retailInvestors">
        <properties>
            <source>org.bear.financeAnalysis.RetailInvestors</source>
        </properties>
    </destination>
    <destination id="redRabbitChart">
        <properties>
            <source>org.bear.financeAnalysis.RedRabbitChart</source>
        </properties>
    </destination>
    <destination id="institutionRatio">
        <properties>
            <source>org.bear.financeAnalysis.InstitutionalRatio</source>
        </properties>
    </destination>
</service>
